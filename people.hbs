<!doctype html>
<html lang="en">

<head>
    <meta property="og:title" content="People | Agentic Learning AI Lab" />
    <meta property="og:description" content="Members of the Agentic Learning AI Lab at NYU." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://agenticlearning.ai/people" />
    <!--Replace with the current website url-->
    <meta property="og:image" content="{{cdnUrl '/assets/images/background/bg3.png'}}" />
    {{> head description="Members of the Agentic Learning AI Lab at NYU."}}
</head>

<body class="tw-flex tw-min-h-[100vh] tw-flex-col tw-bg-[var(--bg)] tw-font-mono">
    {{> header}}

    <section class="tw-flex tw-w-full tw-flex-col tw-p-[5%] tw-mt-[150px] max-lg:tw-p-4">
        <h3 class="text-left tw-text-4xl tw-font-medium max-md:tw-text-2xl">
            People
        </h3>
        <div class="section-underline tw-my-4">
        </div>
        <h4 class="tw-mt-4 text-left tw-text-2xl tw-font-medium max-md:tw-text-xl">
            Current Members
        </h4>

        <div class="tw-mt-8 tw-max-w-[1032px] tw-grid tw-grid-cols-2 sm:tw-grid-cols-3 md:tw-grid-cols-4 lg:tw-grid-cols-5 tw-gap-2">
            {{> people_tab people_current }}
        </div>

        <h4 class="tw-mt-12 text-left tw-text-2xl tw-font-medium max-md:tw-text-xl">
            Alumni
        </h4>
        <div class="tw-mt-8 tw-max-w-[1032px] tw-grid tw-grid-cols-2 sm:tw-grid-cols-3 md:tw-grid-cols-4 lg:tw-grid-cols-5 tw-gap-2">
            {{> people_tab people_alumni }}
        </div>

    </section>


    {{> footer}}
</body>
<script src="/index.js"></script>

</html>