node_modules/
*.DS_Store
out/
staging/
.venv/

# Generated HTML — regenerated by `npm run build:pages`. Cloudflare
# Pages rebuilds on every push, so the committed copies are pure
# duplication. Source-of-truth is the *.hbs templates + data/*.yaml +
# data/projects/*.md. Fresh clones get the HTML via `npm run build:cf`
# (slim) or `npm run build` (full).
/index.html
contact/index.html
research/index.html
research/*/index.html
people/index.html
people/*/index.html
areas/index.html
areas/*/index.html

# Tailwind CSS build output (regenerated by build:tailwind).
css/tailwind-build.css
css/tailwind-runtime.css

# Binary site assets — source-of-truth is local disk + R2 (manifest at
# assets-manifest.json maps logical paths to cdn.agenticlearning.ai URLs).
# Use `npm run pull:r2` to hydrate a fresh clone. See notes/lfs-migration.md.
research/**/*.pdf
research/**/assets/
assets/images/papers/*.png
assets/images/papers/*.jpg
assets/images/papers/*.jpeg
assets/images/papers/*.gif
assets/images/papers/*.webp
assets/images/people/*.png
assets/images/people/*.jpg
assets/images/people/*.jpeg
assets/images/people/*.gif
assets/images/people/*.webp
assets/images/background/*.png
assets/images/background/*.jpg
assets/images/background/*.jpeg
assets/images/background/*.gif
assets/images/background/*.webp
assets/images/home/*.png
assets/images/home/*.jpg
assets/images/home/*.jpeg
assets/images/home/*.gif
assets/images/home/*.webp
assets/images/thumbnails/*.png
assets/images/thumbnails/*.jpg
assets/images/thumbnails/*.jpeg
assets/images/thumbnails/*.gif
assets/images/thumbnails/*.webp
assets/projects/**/*.png
assets/projects/**/*.jpg
assets/projects/**/*.jpeg
assets/projects/**/*.gif
assets/projects/**/*.webp
assets/projects/**/*.mp4
assets/projects/**/*.pdf
assets/projects/**/*.csv
# NB: assets/images/favicons/* and assets/images/logos/* stay in git
# (small same-origin paths used in HTML head). assets/projects/**/*.css
# and *.svg stay in git too (small text, easier to edit in-place).

# Local secrets — see scripts/setup_r2_secrets.sh
.env
.env.local
.env.*.local

# LaTeX source lives as tar.gz on R2, never in git. Local research/<slug>/latex/
# is a transient extract from `npm run latex:fetch <slug>` for editing, and from
# the build pipeline's R2 download branch. See notes/latex-tarball-storage.md.
research/*/latex/
research/*/latex_arXiv/

# Build pipeline cache for downloaded tarballs + compile workdirs.
.cache/

# (Project pages now emit to out/<slug>/ which is covered by the out/ rule
# above. No per-slug gitignore entries needed.)

# Compression markers
research/*/assets/.compressed/
research/*/*.gs-compressed

# Legacy LaTeX path — kept until any leftover papers-latex/ trees are migrated
papers-latex/**/paper.html
papers-latex/**/*.aux
papers-latex/**/*.log
papers-latex/**/*.out
papers-latex/**/*.toc
papers-latex/**/*.bbl
papers-latex/**/*.blg
papers-latex/**/*.xml
papers-latex/**/*.cache
