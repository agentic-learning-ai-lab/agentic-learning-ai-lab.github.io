node_modules/
*.DS_Store
out/
staging/
.venv/

# Local secrets — see scripts/setup_r2_secrets.sh
.env
.env.local
.env.*.local

# LaTeX source lives as tar.gz on R2, never in git. Local research/<slug>/latex/
# is a transient extract from `npm run latex:fetch <slug>` for editing, and from
# the build pipeline's R2 download branch. See notes/latex-tarball-storage.md.
research/*/latex/
research/*/latex_arXiv/

# Build pipeline cache for downloaded tarballs + compile workdirs.
.cache/

# Generated project page output dirs. URL is /<slug>/ at root for inbound-link
# stability, so the build writes here. Gitignored to keep the repo root clean.
# Author runs `npm run build` to regenerate locally; CI rebuilds for deploy.
# Add one line per project as it lands.
# Long-term: migrate to out/<slug>/ via a `npm run preview` task — see
# notes/next-up.md. Until then, list project permalinks here.
/anticipatory-recovery/

# Compression markers
research/*/assets/.compressed/
research/*/*.gs-compressed

# Legacy LaTeX path — kept until any leftover papers-latex/ trees are migrated
papers-latex/**/paper.html
papers-latex/**/*.aux
papers-latex/**/*.log
papers-latex/**/*.out
papers-latex/**/*.toc
papers-latex/**/*.bbl
papers-latex/**/*.blg
papers-latex/**/*.xml
papers-latex/**/*.cache
