# Git LFS - Paper PDFs (final compiled PDFs only; build intermediates are gitignored)
research/**/*.pdf filter=lfs diff=lfs merge=lfs -text

# Git LFS - Paper HTML assets (images from arXiv) + lossless WebP siblings
research/**/assets/**/*.png filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.gif filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.svg filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.webp filter=lfs diff=lfs merge=lfs -text

# LaTeX source lives as tar.gz on R2 — research/<slug>/latex/ never enters git.
# See notes/latex-tarball-storage.md.

# Git LFS - Large site images
assets/images/papers/*.png filter=lfs diff=lfs merge=lfs -text
assets/images/background/*.png filter=lfs diff=lfs merge=lfs -text

# Git LFS - WebP siblings (generated by build/generate_webp.js).
# At q98, backgrounds run ~150-300 KB each; without LFS each re-encode
# would write the full bytes into history. The earlier q85 webps in
# PR #5 are already raw git blobs (history bloat already paid) — this
# rule prevents further bloat going forward.
assets/images/**/*.webp filter=lfs diff=lfs merge=lfs -text

# Git LFS - Project page assets (assets/projects/<slug>/...). Hero
# images, results figures, embedded video/posters, etc. See
# notes/project-pages-migration.md.
assets/projects/**/*.png filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.jpg filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.gif filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.webp filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.pdf filter=lfs diff=lfs merge=lfs -text
assets/projects/**/*.csv filter=lfs diff=lfs merge=lfs -text
