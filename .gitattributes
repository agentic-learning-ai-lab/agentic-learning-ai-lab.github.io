# Git LFS - Paper PDFs (final compiled PDFs only; build intermediates are gitignored)
research/**/*.pdf filter=lfs diff=lfs merge=lfs -text

# Git LFS - Paper HTML assets (images from arXiv)
research/**/assets/**/*.png filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.gif filter=lfs diff=lfs merge=lfs -text
research/**/assets/**/*.svg filter=lfs diff=lfs merge=lfs -text

# LaTeX source lives as tar.gz on R2 — research/<slug>/latex/ never enters git.
# See notes/latex-tarball-storage.md.

# Git LFS - Large site images
assets/images/papers/*.png filter=lfs diff=lfs merge=lfs -text
assets/images/background/*.png filter=lfs diff=lfs merge=lfs -text
