{
  "name": "agentic_learning_ai_lab",
  "version": "1.0.0",
  "private": true,
  "description": "agentic_learning_ai_lab webpage",
  "main": "index.js",
  "scripts": {
    "start:tailwind": "cross-env NODE_ENV=development tailwindcss --postcss -i ./css/tailwind.css -o ./css/tailwind-runtime.css -w",
    "build:tailwind": "cross-env NODE_ENV=production tailwindcss --postcss -i ./css/tailwind.css -o ./css/tailwind-build.css --minify",
    "build:arxiv": "node ./build/build_arxiv_papers.js",
    "build:arxiv:force": "node ./build/build_arxiv_papers.js --force",
    "build:arxiv:pdf": "node ./build/build_arxiv_papers.js --pdf",
    "build:compress": "node ./build/compress_assets.js",
    "build:compress:force": "node ./build/compress_assets.js --force",
    "build:pages": "node ./build/build_pages.js",
    "build:favicons": "node ./build/generate_favicons.js",
    "build:webp": "node ./build/generate_webp.js",
    "build:rewrite-paper-content": "node ./build/rewrite_paper_content.js",
    "build:assemble": "node ./build/assemble_output.js",
    "build": "npm run build:tailwind && node ./build/generate_thumbnails.js && npm run build:webp && node ./build/generate_search_index.js && npm run build:arxiv:pdf && npm run build:rewrite-paper-content && npm run build:compress && npm run build:pages && npm run build:assemble",
    "preview": "npm run build && python3 -m http.server 8000 -d out",
    "setup:python": "python3 -m venv .venv && .venv/bin/pip install --upgrade pip --quiet && .venv/bin/pip install -r build/requirements.txt --quiet",
    "latex:clean": "node ./build/clean_latex.js",
    "latex:fetch": "node ./build/latex_fetch.js",
    "latex:pack": "node ./build/latex_pack.js",
    "latex:update": "node ./build/latex_update.js",
    "sync:r2": "node ./build/sync_to_r2.js"
  },
  "keywords": [],
  "author": "Paul, Mengye Ren",
  "license": "MIT",
  "devDependencies": {
    "@iconify/tailwind": "^1.1.3",
    "chart.js": "^4.4.2",
    "glob": "^7.1.2",
    "gsap": "^3.12.5",
    "handlebars": "^4.7.7",
    "js-yaml": "^3.14.1",
    "moment": "^2.9.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "slugg": "^1.0.0",
    "swiper": "^11.1.1",
    "tailwindcss": "^3.4.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.2.0",
    "postcss": "^8.4.33",
    "postcss-simple-vars": "^7.0.1",
    "sharp": "^0.33.2",
    "tslib": "^2.8.1"
  }
}
