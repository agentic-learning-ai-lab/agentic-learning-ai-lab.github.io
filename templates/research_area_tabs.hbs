<!-- tw-rounded-lg  -->
<!-- hover:tw-shadow-lg tw-transition-shadow tw-duration-300--> 
<!-- max-lg:tw-max-w-[400px] -->
<div class="tw-flex tw-h-fit tw-break-inside-avoid tw-flex-col tw-gap-2 tw-bg-[var(--card-bg)] tw-p-4 max-lg:tw-w-full tw-border-transparent tw-border-2 hover:tw-border-solid hover:tw-border-[var(--border)] tw-transition-all tw-duration-200">
