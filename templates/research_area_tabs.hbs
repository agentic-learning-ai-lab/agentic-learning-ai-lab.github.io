    <div class="tw-h-[200px] tw-w-full tw-overflow-hidden">
        {{{pictureCdn image alt="article image" class="tw-h-full tw-w-full tw-object-cover"}}}
    </div>
    <!--tw-font-semibold  tw-text-2xl -->
    <h3 class="tw-text-xl tw-font-medium tw-mt-4 max-md:tw-text-xl">
        {{{title}}}
    </h3>
    <p class="tw-mt-2 tw-text-[var(--fg-muted)]">
        {{{keywords}}}
    </p>
    <!-- <span>
        <span>Learn more</span>
        <i class="bi bi-arrow-right"></i>
    </span> -->
